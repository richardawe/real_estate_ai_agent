# Copy to .env and fill in values. Never commit .env to version control.

# 32-byte encryption key for PII fields (hex-encoded, 64 chars).
# Generate with: python -c "from engine.crypto import generate_key; print(generate_key())"
PII_ENCRYPTION_KEY=

# OpenRouter API key for LLM calls (extraction and drafting only).
OPENROUTER_API_KEY=

# Self-hosted search API for property listing discovery.
# SEARCH_API_URL: public HTTPS URL of your search API (e.g. a Cloudflare tunnel to localhost:8000)
# SEARCH_API_KEY: the key set in your search-api .env file
SEARCH_API_URL=
SEARCH_API_KEY=

# GitHub token used by workflows_lib when running locally.
# In Actions this is provided automatically via GITHUB_TOKEN.
GITHUB_TOKEN=

# Repository where workflow issues live (owner/repo).
GITHUB_REPOSITORY=richardawe/real_estate_ai_agent
